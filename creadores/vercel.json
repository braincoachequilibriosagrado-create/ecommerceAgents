{
  "rewrites": [
    { "source": "/restablecer", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/restablecer",
      "headers": [
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    },
    {
      "source": "/restablecer/(.*)",
      "headers": [
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
